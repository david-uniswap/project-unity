# =============================================================================
# Project Unity — Environment Variables
# =============================================================================
# Copy to .env and fill in real values before running any service.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------

# Sepolia RPC URL (Alchemy, Infura, or public endpoint).
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY_HERE

# Chain ID (11155111 = Sepolia). Change if deploying to a different network.
CHAIN_ID=11155111

# ---------------------------------------------------------------------------
# Contract addresses
# Set these after running: forge script script/Deploy.s.sol --broadcast
# ---------------------------------------------------------------------------

FAKE_UNI_ADDRESS=0x
PROFILE_REGISTRY_ADDRESS=0x
ROOT_REGISTRY_ADDRESS=0x
REP_EMITTER_ADDRESS=0x
CHALLENGE_REGISTRY_ADDRESS=0x
CHECKPOINT_VERIFIER_ADDRESS=0x

# ---------------------------------------------------------------------------
# Approved LP pools (for 2× Aura boost)
# Comma-separated V2-style pool addresses containing fUNI.
# Leave empty to disable LP boost until pools are deployed.
# Example: 0xPoolA...,0xPoolB...,0xPoolC...
# ---------------------------------------------------------------------------

APPROVED_LP_POOLS=

# Lending / wrapper addresses treated as non-sales (excluded from Aura accrual).
APPROVED_LENDING_CONTRACTS=

# ---------------------------------------------------------------------------
# Protocol givers (bypass Aura allowance checks for REP events)
# ---------------------------------------------------------------------------

# Comma-separated addresses that are allowed to emit REP events without holding
# any Aura. The ChallengeRegistry MUST be included here so it can grant Builder
# REP to successful challengers.
# Example: PROTOCOL_GIVERS=0xChallengeRegistryAddr...
PROTOCOL_GIVERS=

# ---------------------------------------------------------------------------
# Indexer — private key for posting roots onchain
# ---------------------------------------------------------------------------

# The deployer private key (or a dedicated poster key).
# This account must be set as `poster` in RootRegistry.
DEPLOYER_PRIVATE_KEY=0x
POSTER_PRIVATE_KEY=0x

# Block number to start scanning from (0 = genesis, set to deployment block for efficiency).
START_BLOCK=0

# ---------------------------------------------------------------------------
# Pipeline timing
# ---------------------------------------------------------------------------

# Epoch duration in milliseconds. Default: 10 minutes (600000).
EPOCH_DURATION_MS=600000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Used by API and indexer.
DATABASE_URL=postgres://unity:unity@localhost:5432/unity

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------

PORT=3001

# Allowed CORS origin for the frontend. Use "*" during development.
CORS_ORIGIN=*

# ---------------------------------------------------------------------------
# Contract deployment (used by forge script/Deploy.s.sol)
# ---------------------------------------------------------------------------

DEPLOYER_ADDRESS=0x

# Etherscan API key for contract verification.
ETHERSCAN_API_KEY=
